{
  "name": "smg-pos",
  "private": true,
  "version": "1.0.86",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:exe": "npm run build && electron-builder",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.smg.pos",
    "productName": "SMG POS",
    "asarUnpack": [
      "node_modules/whatsapp-web.js/**/*",
      "node_modules/puppeteer-core/**/*"
    ],
    "directories": {
      "output": "build-output"
    },
    "extraResources": [
      {
        "from": "credentials.json",
        "to": "credentials.json",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "initial_db.sqlite",
        "to": "initial_db.sqlite",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "omkaspa9505-svg",
        "repo": "smg-pos-updates",
        "private": true
      }
    ]
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "decimal.js": "^10.6.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.9",
    "googleapis": "^173.0.0",
    "lucide-react": "^1.17.0",
    "number-to-words": "^1.2.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-barcode": "^1.6.1",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.17.0",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "axios": "^1.17.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.2",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-electron": "^1.0.4",
    "vite-plugin-electron-renderer": "^1.0.0"
  }
}
